# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated service worker (Serwist)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map
# .claude — roles/skills are versioned; tasks/handoff/reports/local settings are transient
.claude/tasks/
.claude/handoff/
.claude/reports/
.claude/worktrees/
.claude/worktree/
.claude/settings.local.json
.superpowers/
.worktrees/

# impeccable design skill — third-party install artifacts (the skill code is not
# versioned here; the generated PRODUCT.md / DESIGN.md / .impeccable/design.json ARE,
# and skills-lock.json IS versioned to pin the installed skill version)
/.agents/
/.claude/skills/impeccable
# critique snapshots are regenerated working artifacts, kept locally only
/.impeccable/critique/

# implementation plans are working docs, kept locally only.
# specs (docs/superpowers/specs/) ARE tracked — those are the design intent.
docs/superpowers/plans/

# Capacitor / Android
android/.gradle/
android/app/build/
android/build/
android/.idea/
*.keystore
*.jks

# Capacitor / iOS (Xcode)
ios/App/DerivedData/
ios/App/build/
ios/Pods/
