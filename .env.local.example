# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Drizzle migrations (direct connection)
DATABASE_URL_DIRECT=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Drizzle runtime (transaction mode pooler)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# AES-256 key (openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analytics — set real values in Vercel dashboard for prod
# Project API key: posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder_replace_in_vercel
# Managed reverse proxy domain (ingestion). Direct *.i.posthog.com gets dropped
# by ad/tracker blockers — always go through the proxy in prod.
NEXT_PUBLIC_POSTHOG_HOST=https://e.southern-light.dev

# Sentry error tracking — set real values in Vercel dashboard for prod
# DSN: sentry.io → Project Settings → Client Keys (DSN)
# Errors only send when NODE_ENV === 'production', so local dev sends nothing.
NEXT_PUBLIC_SENTRY_DSN=https://your-key@oXXXX.ingest.us.sentry.io/XXXX
SENTRY_DSN=https://your-key@oXXXX.ingest.us.sentry.io/XXXX

# Google Analytics 4 — only injected when NODE_ENV === 'production' (see
# app/layout.tsx). Leave unset locally; set the real measurement ID only in
# Vercel prod env. Format: G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
